#!/bin/sh

# Get staged PHP files, excluding vendor, node_modules, bootstrap/cache, and generated files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR \
  | grep '\.php$' \
  | grep -v '^vendor/' \
  | grep -v '^node_modules/' \
  | grep -v '^bootstrap/cache/' \
  | grep -v '^storage/' \
  | grep -v '\.generated\.php$')

if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

FAIL=0

# Run Rector if available
if command -v rector >/dev/null 2>&1; then
  echo "Running Rector..."
  echo "$STAGED_FILES" | xargs -L1 -P$(sysctl -n hw.ncpu) rector process --dry-run
  if [ $? -ne 0 ]; then
    echo "Rector found issues in staged files."
    FAIL=1
  fi
else
  echo "Warning: Rector not found, skipping."
fi

# Run Pint if available
if command -v pint >/dev/null 2>&1; then
  echo "Running Pint..."
  echo "$STAGED_FILES" | xargs -L1 -P$(sysctl -n hw.ncpu) pint --test
  if [ $? -ne 0 ]; then
    echo "Pint found style issues in staged files."
    FAIL=1
  fi
else
  echo "Warning: Pint not found, skipping."
fi

if [ $FAIL -ne 0 ]; then
  echo "Commit blocked. Fix the issues above and try again."
  exit 1
fi

echo "All checks passed."
