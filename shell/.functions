# Your custom artisan/testbench function
art() {
    # Check if vendor/bin/testbench exists and is executable
    if [ -x "vendor/bin/testbench" ]; then
        echo "Running vendor/bin/testbench with supplied parameters..."
        ./vendor/bin/testbench "$@"
    # Check if artisan exists and is executable
    elif [ -x "artisan" ]; then
        echo "Running artisan with supplied parameters..."
        php artisan "$@"
    else
        echo "Error: Neither vendor/bin/testbench nor artisan could be found or they are not executable."
        return 1 # Exit the function with an error status
    fi
}

# Commit helper
#
# Defaults:
#   commit                  Generate Conventional Commit msg from staged diff.
#                           If nothing is staged, stage all changes first.
#   commit "fix thing"      Commit with provided msg.
#
# Options:
#   -a, --all               Stage all changes before commit.
#   -e, --edit              Open $EDITOR for generated/provided msg.
#   -p, --push              Run `git push` after successful commit.
#   -u, --push-upstream     Run `git push -u origin HEAD` after successful commit.
#   --dry-run               Print msg/commit command; do not commit.
#   --fixup <ref>           Create fixup commit for ref.
#   --no-verify             Pass through to git commit.
#   --author <author>       Pass through to git commit.
#   --amend, -n, -S, --signoff
#                           Pass through to git commit.
#
# Examples:
#   commit -a -p "fix shell helper"
#   commit -e
#   commit --fixup HEAD~1 -p
commit() {
  local add_all=0
  local dry_run=0
  local edit_msg=0
  local push=0
  local push_upstream=0

  while [[ $# -gt 0 ]]; do
    case "$1" in
      -a|--all) add_all=1 ;;
      -e|--edit) edit_msg=1 ;;
      -p|--push) push=1 ;;
      -u|--push-upstream) push_upstream=1 ;;
      --dry-run) dry_run=1 ;;
      -h|--help)
        _commit_usage
        return 0
        ;;
      *) break ;;
    esac
    shift
  done

  if [[ $add_all -eq 1 ]]; then
    git add -A || return $?
  fi

  if [[ $# -eq 0 ]]; then
    local staged
    staged=$(git diff --cached --stat 2>/dev/null)
    if [[ -z "$staged" ]]; then
      echo "Nothing staged. Staging all..."
      git add -A
    fi

    local result msg
    result=$(opencode -m opencode/big-pickle run "Generate a conventional commit message from the staged changes (git diff --cached). Output ONLY the raw commit message text. Do not wrap it in markdown or code fences." 2>/dev/null)
    msg=$(_opencode_commit_message "$result")
    if [[ -z "$msg" ]]; then
      echo "Failed to generate commit message."
      return 1
    fi
    if [[ $edit_msg -eq 1 ]]; then
      msg=$(_commit_edit_message "$msg") || return $?
    fi
    if [[ $dry_run -eq 1 ]]; then
      printf '%s\n' "$msg"
      return 0
    fi
    printf '%s\n' "$msg" | git commit -F -
    local status=$?
    _commit_push_if_needed $status $push $push_upstream
    return $?
  fi

  local args=()
  local msg=""
  local author=""
  local has_git_message=0

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --amend|-n|-S|--signoff)
        args+=("$1")
        ;;
      --no-verify)
        args+=("$1")
        ;;
      --fixup)
        shift
        if [[ -z "$1" ]]; then
          echo "No fixup target provided."
          return 1
        fi
        args+=("--fixup=$1")
        has_git_message=1
        ;;
      -p|--push)
        push=1
        ;;
      -u|--push-upstream)
        push_upstream=1
        ;;
      --dry-run)
        dry_run=1
        ;;
      -e|--edit)
        edit_msg=1
        ;;
      -a|--all)
        git add -A || return $?
        ;;
      -h|--help)
        _commit_usage
        return 0
        ;;
      --author)
        shift
        if [[ -z "$1" ]]; then
          echo "No author provided."
          return 1
        fi
        author="$1"
        ;;
      -m|--message)
        shift
        if [[ -z "$1" ]]; then
          echo "No commit message provided."
          return 1
        fi
        msg="$1"
        ;;
      *)
        if [[ -z "$msg" ]]; then
          msg="$1"
        else
          msg="$msg $1"
        fi
        ;;
    esac
    shift
  done

  if [[ -n "$author" ]]; then
    args+=("--author=$author")
  fi

  if [[ -z "$msg" && $has_git_message -eq 0 ]]; then
    local result
    result=$(opencode -m opencode/big-pickle run "Generate a conventional commit message from the staged changes (git diff --cached). Output ONLY the raw commit message text. Do not wrap it in markdown or code fences." 2>/dev/null)
    msg=$(_opencode_commit_message "$result")
    if [[ -z "$msg" ]]; then
      echo "Failed to generate commit message."
      return 1
    fi
  fi

  if [[ $edit_msg -eq 1 && -n "$msg" ]]; then
    msg=$(_commit_edit_message "$msg") || return $?
  fi

  if [[ $dry_run -eq 1 ]]; then
    if [[ -n "$msg" ]]; then
      printf '%s\n' "$msg"
    else
      printf 'git commit %q\n' "${args[@]}"
    fi
    return 0
  fi

  if [[ -n "$msg" ]]; then
    git commit "${args[@]}" -m "$msg"
  else
    git commit "${args[@]}"
  fi
  local status=$?
  _commit_push_if_needed $status $push $push_upstream
  return $?
}

_commit_usage() {
  echo "Usage: commit [options] [message]"
  echo "  -a, --all            stage all changes first"
  echo "  -e, --edit           edit generated/provided message"
  echo "  -p, --push           push after successful commit"
  echo "  -u, --push-upstream  push HEAD with upstream after successful commit"
  echo "      --dry-run        print message, do not commit"
  echo "      --fixup <ref>    create fixup commit"
  echo "      --no-verify      skip git hooks"
}

_commit_edit_message() {
  local tmp
  tmp=$(mktemp) || return 1
  printf '%s\n' "$1" > "$tmp"
  ${EDITOR:-vi} "$tmp"
  local status=$?
  if [[ $status -ne 0 ]]; then
    rm -f "$tmp"
    return $status
  fi
  local msg
  msg=$(<"$tmp")
  rm -f "$tmp"
  printf '%s\n' "$msg"
}

_commit_push_if_needed() {
  local status=$1
  local push=$2
  local push_upstream=$3

  if [[ $status -ne 0 ]]; then
    return $status
  fi
  if [[ $push_upstream -eq 1 ]]; then
    git push -u origin HEAD
    return $?
  fi
  if [[ $push -eq 1 ]]; then
    git push
    return $?
  fi
  return 0
}

# Generate commit message from staged diff via opencode (stdout or --copy)
commit-message() {
  local copy=0
  local extra=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --copy)
        copy=1
        ;;
      *)
        if [[ -z "$extra" ]]; then
          extra="$1"
        else
          extra="$extra $1"
        fi
        ;;
    esac
    shift
  done

  local prompt="Inspect the staged changes (git diff --cached). Generate a conventional commit message. Output ONLY the raw commit message text. Do not wrap it in markdown or code fences."
  [[ -n "$extra" ]] && prompt="$prompt Context: $extra"

  local result msg
  result=$(opencode -m opencode/big-pickle run "$prompt" 2>/dev/null)
  msg=$(_opencode_commit_message "$result")

  if [[ -z "$msg" ]]; then
    echo "Failed to generate commit message."
    return 1
  fi

  if [[ $copy -eq 1 ]]; then
    printf '%s\n' "$msg" | pbcopy
    echo "Copied to clipboard"
  else
    printf '%s\n' "$msg"
  fi
}

_opencode_commit_message() {
  printf '%s\n' "$1" | sed -n '/^> /d; /^```/d; /^[[:space:]]*$/d; p'
}

# Rename branch
renamebranch() {
  git branch -m "$1" "$2"
}

# Switch branch using new git switch command
gswitch() {
  git switch "$@"
}

# Stage all and commit quickly
quickcommit() {
  git add . && commit "$@"
}

# Run tests
function p() {
   if [ -f vendor/bin/pest ]; then
      vendor/bin/pest "$@"
   else
      vendor/bin/phpunit "$@"
   fi
}

function pf() {
   if [ -f vendor/bin/pest ]; then
      vendor/bin/pest --filter "$@"
   else
      vendor/bin/phpunit --filter "$@"
   fi
}

# Docker
function ssh-docker() {
   docker exec -it "$@" bash
}

# Create a new directory and enter it
function mkd() {
   mkdir -p "$@" && cd "$@"
}

# Start an HTTP server from a directory, optionally specifying the port
function server() {
	local port="${1:-9000}"
	sleep 2 && open "http://localhost:${port}/" &
	# Set the default Content-Type to `text/plain` instead of `application/octet-stream`
	# And serve everything as UTF-8 (although not technically correct, this doesn’t break anything for binary files)
	python -c $'import SimpleHTTPServer;\nmap = SimpleHTTPServer.SimpleHTTPRequestHandler.extensions_map;\nmap[""] = "text/plain";\nfor key, value in map.items():\n\tmap[key] = value + ";charset=UTF-8";\nSimpleHTTPServer.test();' "$port"
}

# Start a PHP server from a directory, optionally specifying the port
# (Requires PHP 5.4.0+.)
function phpserver() {
	local port="${1:-4000}"
	local ip=$(ipconfig getifaddr en0)
	sleep 2 && open "http://${ip}:${port}/" &
	php -S "${ip}:${port}"
}

# All the dig info
function digga() {
	dig +nocmd "$1" any +multiline +noall +answer
}

function tinker()
{
