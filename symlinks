#!/bin/bash
#
# symlinks - Create symbolic links for dotfiles configuration

echo 'Creating symlinks for dotfiles...'
echo '================================='

# Function to generate gitconfig from template
generate_gitconfig() {
    echo 'Generating git configuration from template...'

    # Load environment variables if .env exists
    if [ -f $HOME/.dotfiles/.env ]; then
        set -a
        source $HOME/.dotfiles/.env
        set +a
    fi

    # Use envsubst to replace environment variables in template
    envsubst < $HOME/.dotfiles/git/.gitconfig.template > $HOME/.dotfiles/.gitconfig.local
}

# Generate and link git configuration
generate_gitconfig
echo 'Linking git configuration...'
rm -f $HOME/.gitconfig
ln -s $HOME/.dotfiles/.gitconfig.local $HOME/.gitconfig

# Global gitignore
echo 'Linking global gitignore...'
rm -f $HOME/.gitignore_global
ln -s $HOME/.dotfiles/git/.gitignore_global $HOME/.gitignore_global

# Zsh configuration
echo 'Linking zsh configuration...'
rm -f $HOME/.zshrc
ln -s $HOME/.dotfiles/shell/.zshrc $HOME/.zshrc

# Vim configuration
echo 'Linking vim configuration...'
rm -f $HOME/.vimrc
ln -s $HOME/.dotfiles/vim/.vimrc $HOME/.vimrc

# Neovim configuration
echo 'Linking neovim configuration...'
mkdir -p $HOME/.config
rm -rf $HOME/.config/nvim
ln -s $HOME/.dotfiles/nvim $HOME/.config/nvim

# Kitty terminal configuration
echo 'Linking kitty configuration...'
mkdir -p $HOME/.config
rm -rf $HOME/.config/kitty
ln -s $HOME/.dotfiles/kitty $HOME/.config/kitty

# GitHub CLI configuration
echo 'Linking GitHub CLI configuration...'
mkdir -p $HOME/.config
rm -rf $HOME/.config/gh
ln -s $HOME/.dotfiles/gh $HOME/.config/gh

# Claude configuration
echo 'Linking Claude configuration...'
rm -rf $HOME/.claude
ln -s $HOME/.dotfiles/claude $HOME/.claude

# Shared agent instructions
echo 'Linking shared agent instructions...'
ln -sfn $HOME/.dotfiles/AGENTS.md $HOME/.dotfiles/claude/CLAUDE.md
mkdir -p $HOME/.codex
ln -sfn $HOME/.dotfiles/AGENTS.md $HOME/.codex/AGENTS.md
mkdir -p $HOME/.pi/agent
ln -sfn $HOME/.dotfiles/AGENTS.md $HOME/.pi/agent/AGENTS.md

# Claude work profile (separate state; shared skills/guidelines)
echo 'Setting up Claude work profile...'
mkdir -p "$HOME/.claude-work"
rm -rf "$HOME/.claude-work/skills"
ln -sfn "$HOME/.agents/skills" "$HOME/.claude-work/skills"
ln -sfn "$HOME/.dotfiles/AGENTS.md" "$HOME/.claude-work/CLAUDE.md"

if [ ! -e "$HOME/.claude-work/settings.json" ]; then
    cp "$HOME/.dotfiles/claude/settings.json" "$HOME/.claude-work/settings.json"
fi

# Opencode configuration
echo 'Linking Opencode configuration...'
rm -rf $HOME/.config/opencode
ln -s $HOME/.dotfiles/opencode $HOME/.config/opencode
ln -sfn $HOME/.dotfiles/AGENTS.md $HOME/.config/opencode/AGENTS.md

# Skills lock file (managed by bunx skills)
# Note: Run `bunx skills experimental_install` to restore ~/.agents/skills from the lock file
echo 'Linking skills lock file...'
mkdir -p $HOME/.agents
if [ ! -e "$HOME/.agents/.skill-lock.json" ]; then
    echo '{}' > "$HOME/.agents/.skill-lock.json"
fi
ln -sfn "$HOME/.dotfiles/skills/skills-lock.json" "$HOME/.agents/.skill-lock.json"
mkdir -p "$HOME/.agents/skills"

# Claude skills
echo 'Linking Claude skills...'
rm -rf "$HOME/.dotfiles/claude/skills"
ln -sfn "$HOME/.agents/skills" "$HOME/.dotfiles/claude/skills"

# Tmux configuration
echo 'Linking tmux configuration...'
rm -f $HOME/.tmux.conf
ln -s $HOME/.dotfiles/.tmux.conf $HOME/.tmux.conf

# Lazygit configuration
echo 'Linking lazygit configuration...'
LAZYGIT_CONFIG_DIR=$(lazygit -cd)
rm -f "$LAZYGIT_CONFIG_DIR/config.yml"
ln -s $HOME/.dotfiles/lazygit/config.yml "$LAZYGIT_CONFIG_DIR/config.yml"

# Rector configuration
echo 'Linking rector configuration...'
rm -f $HOME/.rector/rector.php
mkdir -p $HOME/.rector
ln -s $HOME/.dotfiles/rector.php $HOME/.rector/rector.php

# SSH configuration
echo 'Linking SSH configuration...'
mkdir -p $HOME/.ssh
rm -f $HOME/.ssh/config
ln -s $HOME/.dotfiles/ssh/config $HOME/.ssh/config


echo 'All symlinks created successfully!'
